// Prisma schema for Itinerary App
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USERS
// ============================================================================

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  vacations     Vacation[]

  @@map("users")
}

// ============================================================================
// VACATION & VERSIONING
// ============================================================================

model Vacation {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name              String
  startDate         DateTime
  endDate           DateTime
  
  // Versioning
  version           Int         @default(1)
  parentVacationId  String?     // null for originals, set for variants
  variant           String?     // e.g., "food-focused", "museum-focused"
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  homestays         Homestay[]
  days              Day[]
  activities        Activity[]
  versionHistory    VacationVersion[]

  @@index([userId])
  @@index([parentVacationId])
  @@map("vacations")
}

model VacationVersion {
  id                String      @id @default(cuid())
  vacationId        String
  vacation          Vacation    @relation(fields: [vacationId], references: [id], onDelete: Cascade)

  versionNumber     Int
  snapshot          Json        // Full vacation state at this version (days, activities, homestays)
  reason            String?     // e.g., "User reverted to earlier plan", "AI suggestions applied"
  
  createdAt         DateTime    @default(now())

  @@unique([vacationId, versionNumber])
  @@index([vacationId])
  @@map("vacation_versions")
}

// ============================================================================
// HOMESTAYS
// ============================================================================

model Homestay {
  id                String      @id @default(cuid())
  vacationId        String
  vacation          Vacation    @relation(fields: [vacationId], references: [id], onDelete: Cascade)

  name              String
  address           String
  coordinates       Json?       // { lat: Float, lng: Float }
  
  checkInDate       DateTime
  checkOutDate      DateTime
  
  notes             String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  days              Day[]

  @@index([vacationId])
  @@map("homestays")
}

// ============================================================================
// DAYS
// ============================================================================

model Day {
  id                String      @id @default(cuid())
  vacationId        String
  vacation          Vacation    @relation(fields: [vacationId], references: [id], onDelete: Cascade)
  
  // Homestay is optional - can have days without a specific homestay
  homestayId        String?
  homestay          Homestay?   @relation(fields: [homestayId], references: [id], onDelete: SetNull)

  date              DateTime    @db.Date
  notes             String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  activities        Activity[]

  @@unique([vacationId, date])
  @@index([vacationId])
  @@index([homestayId])
  @@map("days")
}

// NOTE on Activity lifecycle:
// - dayId is nullable: null means activity is in the unassigned pool
// - When a day is deleted: its activities move to unassigned pool (dayId → null)
// - Hard delete: user explicitly deletes activity → sets deletedAt timestamp
//   (signals to AI that this activity type is rejected)
// - Soft delete: moving to unassigned pool (dayId → null, deletedAt remains null)
//   (user may reassign to another day later)
// - Query filters: exclude deletedAt activities by default, include with ?includeDeleted=true
// - Activities can be duplicated - no uniqueness constraint prevents same activity on multiple days.

// ============================================================================
// ACTIVITIES
// ============================================================================

enum ActivityType {
  RESTAURANT
  SIGHTSEEING
  ACTIVITY
  TRAVEL
}

enum ActivityPriority {
  MUST_HAVE
  NICE_TO_HAVE
  FLEXIBLE
}

enum TimeConstraint {
  SPECIFIC_TIME    // Must happen at exact time
  MORNING          // Morning preferred
  AFTERNOON        // Afternoon preferred
  EVENING          // Evening preferred
  ANYTIME          // Any time works
}

enum ActivitySource {
  USER_ENTERED
  AI_SUGGESTED
}

model Activity {
  id                String      @id @default(cuid())
  
  // Day assignment (nullable = unassigned pool)
  dayId             String?
  day               Day?        @relation(fields: [dayId], references: [id], onDelete: SetNull)
  
  vacationId        String      // Denormalized for easier queries
  vacation          Vacation    @relation(fields: [vacationId], references: [id], onDelete: Cascade)

  type              ActivityType
  name              String
  location          String      // User-friendly name/address
  coordinates       Json?       // { lat: Float, lng: Float }
  googlePlacesId    String?     // Reference to Google Places
  
  // Time information
  // Activities are sorted by:
  // 1. time (if set, ascending)
  // 2. position (manual order for unscheduled activities)
  // 3. createdAt (fallback)
  time              String?     // HH:mm format (null if flexible)
  duration          Int?        // Duration in minutes
  timeConstraint    TimeConstraint
  position          Int?        // Manual sort order within a day (for activities without specific time)
  
  // Priority & source
  priority          ActivityPriority
  source            ActivitySource  @default(USER_ENTERED)
  
  notes             String?
  
  // Travel time (to next activity in order)
  travelTimeTo      Json?       // { nextActivityId: String, minutes: Int, distance: Float, mode: "WALKING" | "TRANSIT" | "DRIVING" }
  
  // Future: cost tracking
  estimatedCost     Float?
  
  // Metadata for future enrichment (ratings, photos, hours, etc.)
  metadata          Json?       // {rating, openNow, hours, photos, ...}

  // Soft delete for hard-deletion signal to AI
  // null = active, non-null = hard-deleted by user (AI sees this as rejection)
  deletedAt         DateTime?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([dayId])
  @@index([vacationId])
  @@index([googlePlacesId])
  @@map("activities")
}

